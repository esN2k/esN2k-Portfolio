    font-family: 'JetBrains Mono';
    font-style: normal;
    font-weight: 400 700;
    font-display: swap;
    src: url('assets/fonts/jetbrains-mono-latin-ext.woff2') format('woff2');
    unicode-range:
        U+0100-02BA,
        U+02BD-02C5,
        U+02C7-02CC,
        U+02CE-02D7,
        U+02DD-02FF,
        U+0304,
        U+0308,
        U+0329,
        U+1D00-1DBF,
        U+1E00-1E9F,
        U+1EF2-1EFF,
        U+2020,
        U+20A0-20AB,
        U+20AD-20C0,
        U+2113,
        U+2C60-2C7F,
        U+A720-A7FF;
}

@font-face {
    font-family: 'JetBrains Mono';
    font-style: normal;
    font-weight: 400 700;
    font-display: swap;
    src: url('assets/fonts/jetbrains-mono-latin.woff2') format('woff2');
    unicode-range:
        U+0000-00FF,
        U+0131,
        U+0152-0153,
        U+02BB-02BC,
        U+02C6,
        U+02DA,
        U+02DC,
        U+0304,
        U+0308,
        U+0329,
        U+2000-206F,
        U+20AC,
        U+2122,
        U+2191,
        U+2193,
        U+2212,
        U+2215,
        U+FEFF,
        U+FFFD;
}

:root {
    --bg-primary: #050505;
    --bg-secondary: #0d0d0d;
    --bg-card: rgba(255, 255, 255, 0.02);
    --bg-card-hover: rgba(255, 255, 255, 0.05);
    --border-color: rgba(255, 255, 255, 0.06);
    --border-glow: rgba(139, 92, 246, 0.4);

    --text-primary: #f5f5f5;
    --text-secondary: #b0b0c0;
    --text-muted: #70707e;

    --accent-1: #9333ea;
    --accent-2: #06b6d4;
    --accent-3: #f59e0b;
    --accent-purple-glow: rgba(147, 51, 234, 0.5);
    --accent-cyan-glow: rgba(6, 182, 212, 0.5);
    --accent-gold-glow: rgba(245, 158, 11, 0.5);
    --gradient-primary: linear-gradient(135deg, var(--accent-1), var(--accent-2));
    --gradient-text: linear-gradient(135deg, #c084fc, #38bdf8);
    --gradient-hero: linear-gradient(
        160deg,
        rgba(147, 51, 234, 0.2) 0%,
        transparent 50%,
        rgba(6, 182, 212, 0.15) 100%
    );

    --font-sans: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    --font-mono: 'JetBrains Mono', monospace;

    --radius-sm: 8px;
    --radius-md: 16px;
    --radius-lg: 24px;
    --radius-full: 9999px;

    --transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

*,
*::before,
*::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}

html {
    scroll-behavior: smooth;
    scroll-padding-top: 88px;
}

body {
    min-height: 100vh;
    font-family: var(--font-sans);
    background: var(--bg-primary);
    color: var(--text-primary);
    line-height: 1.7;
    overflow-x: hidden;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
}

body.loading {
    overflow: hidden;
}

body.menu-open {
    overflow: hidden;
}

/* ===== PAGE LOADER ===== */
.page-loader {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-primary);
    transition: opacity 0.6s ease, visibility 0.6s ease;
}

.page-loader.hidden {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
}

.loader-content {
    text-align: center;
}

.loader-logo {
    width: 80px;
    height: 80px;
    margin: 0 auto 24px;
    animation: loader-pulse 1.5s ease-in-out infinite;
}

.loader-bar {
    width: 200px;
    height: 3px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 3px;
    overflow: hidden;
}

.loader-progress {
    height: 100%;
    background: var(--gradient-primary);
    border-radius: 3px;
    animation: loader-fill 1.5s ease-out forwards;
}

@keyframes loader-pulse {
    0%, 100% {
        transform: scale(1);
        filter: drop-shadow(0 0 20px rgba(147, 51, 234, 0.5));
    }
    50% {
        transform: scale(1.1);
        filter: drop-shadow(0 0 40px rgba(147, 51, 234, 0.8));
    }
}

@keyframes loader-fill {
    0% { width: 0%; }
    100% { width: 100%; }
}

/* ===== PAGE ENTRANCE ANIMATIONS ===== */
.page-enter {
    opacity: 0;
}

.page-enter.loaded {
    opacity: 1;
}

.hero-enter {
    opacity: 0;
    transform: translateY(40px);
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
}

.hero-enter.visible {
    opacity: 1;
    transform: translateY(0);
}

.hero-enter-delay-1 { transition-delay: 0.1s; }
.hero-enter-delay-2 { transition-delay: 0.2s; }
.hero-enter-delay-3 { transition-delay: 0.3s; }
.hero-enter-delay-4 { transition-delay: 0.4s; }
.hero-enter-delay-5 { transition-delay: 0.5s; }
.hero-enter-delay-6 { transition-delay: 0.6s; }

button,
a,
input,
textarea,
select {
    font: inherit;
}

a {
    color: inherit;
    text-decoration: none;
}

ul {
    list-style: none;
}

img {
    display: block;
    max-width: 100%;
    height: auto;
}

strong {
    color: var(--text-primary);
    font-weight: 600;
}

.skip-link {
    position: fixed;
    top: 16px;
    left: 16px;
    z-index: 2000;
    padding: 12px 16px;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-sm);
    background: var(--bg-secondary);
    color: var(--text-primary);
    transform: translateY(-180%);
    transition: transform var(--transition);
}

.skip-link:focus {
    transform: translateY(0);
}

.sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
}

a:focus-visible,
button:focus-visible {
    outline: 2px solid var(--accent-2);
    outline-offset: 4px;
}

.container {
    width: min(1100px, calc(100% - 48px));
    margin: 0 auto;
}

.section {
    position: relative;
    padding: 120px 0;
    scroll-margin-top: 100px;
    content-visibility: auto;
    contain-intrinsic-size: 1px 900px;
}

.section-bg {
    overflow: hidden;
}

.section-glow {
    position: absolute;
    width: 500px;
    height: 500px;
    border-radius: 50%;
    filter: blur(120px);
    opacity: 0.15;
    pointer-events: none;
    z-index: 0;
}

.section-glow-left {
    top: 20%;
    left: -150px;
    background: linear-gradient(135deg, var(--accent-1), var(--accent-2));
}

.section-glow-right {
    top: 30%;
    right: -150px;
    background: linear-gradient(135deg, var(--accent-2), var(--accent-3));
}

.section-glow-center {
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: radial-gradient(circle, var(--accent-1) 0%, var(--accent-2) 50%, transparent 70%);
    width: 600px;
    height: 600px;
    opacity: 0.12;
}

.section-bg .container {
    position: relative;
    z-index: 1;
}

.section-title {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 60px;
    font-size: clamp(1.8rem, 4vw, 2.4rem);
    font-weight: 700;
}

.section-number {
    color: var(--accent-1);
    font-family: var(--font-mono);
    font-size: 0.9rem;
    font-weight: 500;
}

.section-title::after {
    content: '';
    flex: 1;
    height: 1px;
    margin-left: 16px;
    background: var(--border-color);
}

#navbar {
    position: fixed;
    inset: 0 0 auto;
    z-index: 1000;
    padding: 16px 0;
    transition: var(--transition);
    backdrop-filter: blur(0);
}

#navbar.scrolled {
    padding: 10px 0;
    background: rgba(5, 5, 5, 0.92);
    border-bottom: 1px solid var(--border-color);
    backdrop-filter: blur(24px);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.4);
}

.nav-container {
    width: min(1100px, calc(100% - 48px));
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
}

.nav-logo {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 1.5rem;
    font-weight: 800;
    letter-spacing: -0.02em;
}

.nav-logo-img {
    width: 36px;
    height: 36px;
    object-fit: contain;
    border-radius: 50%;
}

.nav-logo-text {
    display: inline;
}

.nav-logo .accent {
    color: var(--accent-1);
}

.nav-panel {
    display: flex;
    align-items: center;
    gap: 24px;
}

.nav-links {
    display: flex;
    align-items: center;
    gap: 32px;
}

.nav-links a {
    position: relative;
    color: var(--text-secondary);
    font-size: 0.875rem;
    font-weight: 500;
    transition: var(--transition);
    padding: 4px 0;
}

.nav-links a:hover,
.nav-links a.active,
.nav-links a[aria-current='page'] {
    color: var(--text-primary);
}

.nav-links a::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -4px;
    width: 0;
    height: 2px;
    background: var(--gradient-primary);
    border-radius: 2px;
    transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 0 8px rgba(147, 51, 234, 0.5);
}

.nav-links a:hover::after,
.nav-links a.active::after,
.nav-links a[aria-current='page']::after {
    width: 100%;
}

.nav-links a::before {
    content: '';
    position: absolute;
    inset: -4px -8px;
    border-radius: var(--radius-sm);
    background: rgba(147, 51, 234, 0.1);
    opacity: 0;
    transition: opacity 0.3s ease;
    z-index: -1;
}

.nav-links a:hover::before {
    opacity: 1;
}

.nav-cta {
    padding: 10px 20px;
    color: #fff !important;
    background: var(--gradient-primary) !important;
    border-radius: var(--radius-full);
    font-weight: 600 !important;
    font-size: 0.8rem;
    white-space: nowrap;
    box-shadow: 0 2px 12px rgba(147, 51, 234, 0.3);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.nav-cta:hover {
    transform: translateY(-2px) scale(1.02);
    box-shadow: 
        0 6px 24px rgba(147, 51, 234, 0.5),
        0 0 40px rgba(147, 51, 234, 0.2);
}

.nav-cta::after,
.nav-cta::before {
    display: none !important;
}

.lang-switcher {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 4px;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-full);
    background: rgba(255, 255, 255, 0.03);
}

.lang-switch {
    min-width: 48px;
    padding: 7px 12px;
    border: 0;
    border-radius: var(--radius-full);
    background: transparent;
    color: var(--text-secondary);
    cursor: pointer;
    transition: var(--transition);
}

.lang-switch:hover,
.lang-switch.active {
    color: #fff;
    background: var(--gradient-primary);
}

.nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    padding: 4px;
    border: 0;
    background: none;
    cursor: pointer;
}

.nav-toggle span {
    display: block;
    width: 24px;
    height: 2px;
    border-radius: 2px;
    background: var(--text-primary);
    transition: var(--transition);
}

.nav-toggle.active span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
}

.nav-toggle.active span:nth-child(2) {
    opacity: 0;
}

.nav-toggle.active span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
}

#hero {
    position: relative;
    display: flex;
    align-items: center;
    min-height: 100vh;
    overflow: hidden;
}

.hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
}

#heroParticles {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0.7;
}

.hero-gradient {
    position: absolute;
    inset: 0;
    background: var(--gradient-hero);
}

.hero-grid {
    position: absolute;
    inset: 0;
    background-image:
        linear-gradient(rgba(147, 51, 234, 0.05) 1px, transparent 1px),
        linear-gradient(90deg, rgba(6, 182, 212, 0.05) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse 60% 60% at 50% 50%, black 20%, transparent 70%);
    animation: grid-pulse 8s ease-in-out infinite;
}

@keyframes grid-pulse {
    0%, 100% {
        opacity: 0.4;
    }
    50% {
        opacity: 0.8;
    }
}

.hero-grid::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(
        circle at 30% 40%,
        rgba(147, 51, 234, 0.15) 0%,
        transparent 50%
    ), radial-gradient(
        circle at 70% 60%,
        rgba(6, 182, 212, 0.12) 0%,
        transparent 50%
    );
    animation: orb-float 10s ease-in-out infinite;
}

@keyframes orb-float {
    0%, 100% {
        transform: translate(0, 0) scale(1);
    }
    50% {
        transform: translate(30px, -30px) scale(1.1);
    }
}

.hero-content {
    position: relative;
    z-index: 1;
    width: min(1100px, calc(100% - 48px));
    margin: 0 auto;
    padding-top: 100px;
}

.hero-logo-wrapper {
    display: flex;
    justify-content: center;
    margin-bottom: 24px;
}

.hero-logo {
    width: 180px;
    height: auto;
    filter: drop-shadow(0 0 30px rgba(147, 51, 234, 0.4))
            drop-shadow(0 0 60px rgba(147, 51, 234, 0.2));
    animation: hero-logo-float 6s ease-in-out infinite;
}

@keyframes hero-logo-float {
    0%, 100% {
        transform: translateY(0) scale(1);
    }
    50% {
        transform: translateY(-8px) scale(1.02);
    }
}

.hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 32px;
    padding: 6px 16px;
    color: var(--accent-2);
    border: 1px solid rgba(6, 182, 212, 0.3);
    border-radius: var(--radius-full);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: rgba(6, 182, 212, 0.08);
    backdrop-filter: blur(8px);
    animation: badge-glow 3s ease-in-out infinite;
    position: relative;
    overflow: hidden;
}

.hero-badge::before {
    content: '';
    position: absolute;
    top: 50%;
    left: -100%;
    width: 200%;
    height: 200%;
    background: linear-gradient(
        90deg,
        transparent,
        rgba(6, 182, 212, 0.15),
        transparent
    );
    transform: translateY(-50%);
    animation: badge-shimmer 4s ease-in-out infinite;
}

@keyframes badge-shimmer {
    0%, 100% { left: -100%; }
    50% { left: 100%; }
}

@keyframes badge-glow {
    0%, 100% {
        box-shadow: 
            0 0 8px rgba(6, 182, 212, 0.15),
            0 0 16px rgba(6, 182, 212, 0.08),
            inset 0 0 8px rgba(6, 182, 212, 0.05);
    }
    50% {
        box-shadow: 
            0 0 20px rgba(6, 182, 212, 0.3),
            0 0 40px rgba(6, 182, 212, 0.15),
            inset 0 0 12px rgba(6, 182, 212, 0.1);
    }
}

.hero-greeting {
    display: block;
    margin-bottom: 8px;
    color: var(--text-secondary);
    font-size: clamp(1rem, 2.5vw, 1.3rem);
    font-weight: 400;
}

.hero-name {
    display: block;
    max-width: 12ch;
    background: var(--gradient-text);
    background-clip: text;
    -webkit-text-fill-color: transparent;
    -webkit-background-clip: text;
    font-size: clamp(2.8rem, 7vw, 5rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    line-height: 1.1;
    position: relative;
    animation: name-glow 4s ease-in-out infinite;
}

@keyframes name-glow {
    0%, 100% {
        filter: drop-shadow(0 0 12px rgba(192, 132, 252, 0.4))
                drop-shadow(0 0 24px rgba(147, 51, 234, 0.2));
    }
    50% {
        filter: drop-shadow(0 0 20px rgba(56, 189, 248, 0.5))
                drop-shadow(0 0 40px rgba(6, 182, 212, 0.3));
    }
}

.hero-name:hover {
    animation: glitch 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94) both infinite;
}

@keyframes glitch {
    0%, 100% {
        transform: translate(0);
        text-shadow:
            2px 2px 0 rgba(147, 51, 234, 0.7),
            -2px -2px 0 rgba(6, 182, 212, 0.7);
    }
    20% {
        transform: translate(-2px, 2px);
        text-shadow:
            3px 3px 0 rgba(147, 51, 234, 0.7),
            -3px -3px 0 rgba(6, 182, 212, 0.7);
    }
    40% {
        transform: translate(-2px, -2px);
        text-shadow:
            -2px 2px 0 rgba(147, 51, 234, 0.7),
            2px -2px 0 rgba(6, 182, 212, 0.7);
    }
    60% {
        transform: translate(2px, 2px);
        text-shadow:
            2px -2px 0 rgba(147, 51, 234, 0.7),
            -2px 2px 0 rgba(6, 182, 212, 0.7);
    }
    80% {
        transform: translate(2px, -2px);
        text-shadow:
            -3px -3px 0 rgba(147, 51, 234, 0.7),
            3px 3px 0 rgba(6, 182, 212, 0.7);
    }
}

.hero-role-wrapper {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 16px;
    font-size: clamp(1.1rem, 2.5vw, 1.5rem);
}

.hero-role-prefix {
    color: var(--text-secondary);
    font-weight: 400;
}

.hero-role {
    min-height: 1.4em;
    color: var(--accent-1);
    font-weight: 600;
    transition: text-shadow 0.15s ease;
}

.hero-role.typing-glitch {
    animation: typing-glitch 0.15s ease-out;
}

@keyframes typing-glitch {
    0% {
        transform: translateX(0);
        text-shadow: none;
    }
    25% {
        transform: translateX(-3px);
        text-shadow: 
            2px 0 rgba(147, 51, 234, 0.8),
            -2px 0 rgba(6, 182, 212, 0.8);
    }
    50% {
        transform: translateX(3px);
        text-shadow: 
            -2px 0 rgba(147, 51, 234, 0.8),
            2px 0 rgba(6, 182, 212, 0.8);
    }
    75% {
        transform: translateX(-1px);
        text-shadow: 
            1px 0 rgba(147, 51, 234, 0.5),
            -1px 0 rgba(6, 182, 212, 0.5);
    }
    100% {
        transform: translateX(0);
        text-shadow: none;
    }
}

.hero-cursor {
    color: var(--accent-1);
    font-weight: 300;
    animation: cursor-blink 1s ease-in-out infinite;
    text-shadow: 0 0 8px rgba(147, 51, 234, 0.6);
}

@keyframes cursor-blink {
    0%, 100% {
        opacity: 1;
        text-shadow: 0 0 8px rgba(147, 51, 234, 0.6);
    }
    50% {
        opacity: 0.2;
        text-shadow: 0 0 4px rgba(147, 51, 234, 0.3);
    }
}

.hero-desc {
    max-width: 560px;
    margin-top: 24px;
    color: var(--text-secondary);
    font-size: 1.05rem;
    line-height: 1.8;
}

.hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    margin-top: 40px;
}

.btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 32px;
    border: 0;
    border-radius: var(--radius-full);
    cursor: pointer;
    font-size: 0.95rem;
    font-weight: 600;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
}

.btn::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: var(--radius-full);
    opacity: 0;
    transition: opacity 0.3s ease;
}

.btn-primary {
    color: #fff;
    background: var(--gradient-primary);
    box-shadow: 0 4px 24px rgba(147, 51, 234, 0.3);
}

.btn-primary:hover {
    transform: translateY(-3px) scale(1.02);
    box-shadow:
        0 12px 48px rgba(147, 51, 234, 0.45),
        0 0 32px rgba(147, 51, 234, 0.3);
}

.btn-primary::before {
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.2), transparent);
}

.btn-primary:hover::before {
    opacity: 1;
}

.btn-ghost {
    color: var(--text-primary);
    border: 1px solid var(--border-color);
    backdrop-filter: blur(8px);
}

.btn-ghost:hover {
    transform: translateY(-3px);
    border-color: var(--accent-1);
    background: rgba(147, 51, 234, 0.12);
    box-shadow: 0 8px 32px rgba(147, 51, 234, 0.2);
}

.hero-stats {
    display: flex;
    gap: 48px;
    margin-top: 64px;
    padding-top: 32px;
    border-top: 1px solid var(--border-color);
}

.stat-value {
    display: inline-flex;
    align-items: baseline;
    gap: 4px;
    line-height: 1;
}

.stat-number,
.stat-suffix {
    background: var(--gradient-text);
    background-clip: text;
    -webkit-text-fill-color: transparent;
    -webkit-background-clip: text;
}

.stat-number {
    font-size: 2.4rem;
    font-weight: 800;
}

.stat-suffix {
    font-size: 1.15rem;
    font-weight: 700;
}

.stat-label {
    display: block;
    margin-top: 6px;
    color: var(--text-muted);
    font-size: 0.8rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
}

.scroll-indicator {
    position: absolute;
    left: 50%;
    bottom: 40px;
    transform: translateX(-50%);
}

.scroll-line {
    width: 1px;
    height: 60px;
    background: linear-gradient(to bottom, var(--accent-1), transparent);
    animation: scroll-pulse 2s ease-in-out infinite;
}

@keyframes scroll-pulse {
    0%,
    100% {
        opacity: 0.3;
        transform: scaleY(0.6);
    }

    50% {
        opacity: 1;
        transform: scaleY(1);
    }
}

.glass-card {
    padding: 32px;
    background: linear-gradient(
        135deg,
        rgba(255, 255, 255, 0.03) 0%,
        rgba(255, 255, 255, 0.01) 100%
    );
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
}

.glass-card::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: var(--radius-md);
    padding: 1px;
    background: linear-gradient(
        135deg,
        rgba(147, 51, 234, 0.2) 0%,
        transparent 50%,
        rgba(6, 182, 212, 0.2) 100%
    );
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
}

.glass-card:hover {
    transform: translateY(-8px) scale(1.01);
    background: linear-gradient(
        135deg,
        rgba(255, 255, 255, 0.05) 0%,
        rgba(255, 255, 255, 0.02) 100%
    );
    border-color: transparent;
    box-shadow:
        0 25px 80px rgba(147, 51, 234, 0.15),
        0 10px 40px rgba(0, 0, 0, 0.3),
        0 0 60px rgba(147, 51, 234, 0.08),
        inset 0 1px 0 rgba(255, 255, 255, 0.1);
}

.glass-card:hover::before {
    opacity: 1;
}

.bento-grid {
    display: grid;
    gap: 20px;
}

.bento-about {
    grid-template-columns: minmax(300px, 380px) 1fr 1fr;
    grid-template-rows: auto auto auto;
    grid-template-areas:
        "image bio bio"
        "image thesis thesis"
        "image lang1 lang2";
}

.bento-about .bento-image { grid-area: image; }
.bento-about .bento-bio { grid-area: bio; }
.bento-about .bento-thesis { grid-area: thesis; }
.bento-about .bento-lang:first-of-type { grid-area: lang1; }
.bento-about .bento-lang:last-of-type { grid-area: lang2; }

.bento-item {
    min-height: 0;
}

.bento-image {
    position: relative;
    border-radius: var(--radius-md);
    overflow: hidden;
    min-height: 400px;
}

.bento-bio p {
    color: var(--text-secondary);
    font-size: 1rem;
    line-height: 1.8;
}

.bento-bio p:not(:last-child) {
    margin-bottom: 16px;
}

.bento-thesis {
    display: flex;
    flex-direction: column;
    gap: 12px;
}

.bento-thesis h3 {
    font-size: 1rem;
    font-weight: 700;
    color: var(--accent-2);
}

.bento-thesis p {
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.7;
}

.bento-icon {
    font-size: 1.8rem;
}

.bento-lang {
    padding: 20px !important;
}

.bento-lang .lang-card {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 0;
    background: transparent;
    border: none;
}

.about-image-frame {
    position: relative;
    z-index: 1;
    overflow: hidden;
    border-radius: var(--radius-md);
    height: 100%;
}

.about-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(20%) contrast(1.05);
    transition: var(--transition);
}

.bento-image:hover .about-image {
    filter: none;
    transform: scale(1.03);
}

.about-image-decoration {
    position: absolute;
    inset: 12px -12px -12px 12px;
    border: 2px solid var(--accent-1);
    border-radius: var(--radius-md);
    opacity: 0.3;
    transition: var(--transition);
    pointer-events: none;
}

.bento-image:hover .about-image-decoration {
    inset: 8px -8px -8px 8px;
    opacity: 0.6;
}

.flag {
    font-size: 1.2em;
}

.lang-flag {
    font-size: 1.8rem;
}

.lang-name {
    font-size: 0.95rem;
    font-weight: 600;
}

.lang-level {
    margin-left: auto;
    color: var(--accent-2);
    font-size: 0.8rem;
    font-weight: 500;
}

.bento-skills {
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto auto;
    grid-template-areas:
        "brain hands"
        "voice voice";
}

.skill-brain { grid-area: brain; }
.skill-hands { grid-area: hands; }
.skill-voice { grid-area: voice; }

.skill-category {
    position: relative;
}

.skill-category[data-accent="purple"]:hover {
    box-shadow:
        0 25px 80px rgba(147, 51, 234, 0.2),
        0 0 60px rgba(147, 51, 234, 0.1);
}

.skill-category[data-accent="cyan"]:hover {
    box-shadow:
        0 25px 80px rgba(6, 182, 212, 0.2),
        0 0 60px rgba(6, 182, 212, 0.1);
}

.skill-category[data-accent="gold"]:hover {
    box-shadow:
        0 25px 80px rgba(245, 158, 11, 0.2),
        0 0 60px rgba(245, 158, 11, 0.1);
}

.skill-category[data-accent="cyan"]::before {
    background: linear-gradient(
        135deg,
        rgba(6, 182, 212, 0.2) 0%,
        transparent 50%,
        rgba(147, 51, 234, 0.2) 100%
    );
}

.skill-category[data-accent="gold"]::before {
    background: linear-gradient(
        135deg,
        rgba(245, 158, 11, 0.2) 0%,
        transparent 50%,
        rgba(147, 51, 234, 0.2) 100%
    );
}

.skill-icon {
    margin-bottom: 16px;
    font-size: 2.2rem;
}

.skill-category h3 {
    margin-bottom: 20px;
    font-size: 1.15rem;
    font-weight: 700;
}

.skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
}

.skill-tag {
    padding: 8px 16px;
    color: var(--text-primary);
    background: rgba(147, 51, 234, 0.1);
    border: 1px solid rgba(147, 51, 234, 0.2);
    border-radius: var(--radius-full);
    font-size: 0.8rem;
    font-weight: 500;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    cursor: default;
}

.skill-category[data-accent="cyan"] .skill-tag {
    background: rgba(6, 182, 212, 0.1);
    border-color: rgba(6, 182, 212, 0.2);
}

.skill-category[data-accent="gold"] .skill-tag {
    background: rgba(245, 158, 11, 0.1);
    border-color: rgba(245, 158, 11, 0.2);
}

.skill-tag:hover {
    transform: translateY(-3px) scale(1.05);
    background: rgba(147, 51, 234, 0.25);
    border-color: var(--accent-1);
    box-shadow: 0 8px 24px rgba(147, 51, 234, 0.3);
}

.skill-category[data-accent="cyan"] .skill-tag:hover {
    background: rgba(6, 182, 212, 0.25);
    border-color: var(--accent-2);
    box-shadow: 0 8px 24px rgba(6, 182, 212, 0.3);
}

.skill-category[data-accent="gold"] .skill-tag:hover {
    background: rgba(245, 158, 11, 0.25);
    border-color: var(--accent-3);
    box-shadow: 0 8px 24px rgba(245, 158, 11, 0.3);
}

.timeline {
    position: relative;
    padding-left: 48px;
}

.timeline::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(
        to bottom,
        var(--accent-1) 0%,
        var(--accent-2) 50%,
        rgba(6, 182, 212, 0.2) 100%
    );
    box-shadow: 0 0 12px rgba(147, 51, 234, 0.3);
}

.timeline-item {
    position: relative;
    margin-bottom: 48px;
    opacity: 0;
    transform: translateX(-20px);
    transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1);
}

.timeline-item.visible {
    opacity: 1;
    transform: translateX(0);
}

.timeline-item:last-child {
    margin-bottom: 0;
}

.timeline-marker {
    position: absolute;
    left: -55px;
    top: 36px;
    width: 16px;
    height: 16px;
    border: 3px solid var(--bg-primary);
    border-radius: 50%;
    background: var(--accent-1);
    box-shadow: 
        0 0 0 4px rgba(147, 51, 234, 0.2),
        0 0 20px rgba(147, 51, 234, 0.4);
    transition: all 0.3s ease;
}

.timeline-item:hover .timeline-marker {
    transform: scale(1.3);
    box-shadow: 
        0 0 0 6px rgba(147, 51, 234, 0.3),
        0 0 30px rgba(147, 51, 234, 0.6);
}

.timeline-marker::before {
    content: '';
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    background: rgba(147, 51, 234, 0.3);
    animation: marker-pulse 2s ease-in-out infinite;
}

@keyframes marker-pulse {
    0%, 100% {
        transform: scale(1);
        opacity: 0.5;
    }
    50% {
        transform: scale(1.5);
        opacity: 0;
    }
}

.timeline-header {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 8px;
}

.timeline-header h3 {
    font-size: 1.15rem;
    font-weight: 700;
    transition: color 0.3s ease;
}

.timeline-item:hover .timeline-header h3 {
    color: var(--accent-1);
}

.timeline-company {
    color: var(--accent-2);
    font-size: 0.9rem;
    font-weight: 500;
}

.timeline-date {
    display: inline-block;
    margin-bottom: 16px;
    padding: 4px 12px;
    color: var(--text-muted);
    background: rgba(147, 51, 234, 0.1);
    border-radius: var(--radius-full);
    font-family: var(--font-mono);
    font-size: 0.75rem;
}

.timeline-content li {
    position: relative;
    margin-bottom: 10px;
    padding-left: 20px;
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.6;
}

.timeline-content li::before {
    content: '▹';
    position: absolute;
    left: 0;
    color: var(--accent-1);
    font-weight: 700;
    transition: transform 0.3s ease;
}

.timeline-content li:hover::before {
    transform: translateX(4px);
}

.projects-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: auto auto;
    gap: 20px;
}

.projects-grid .project-card:first-child {
    grid-column: span 2;
}

.project-card {
    display: flex;
    flex-direction: column;
    position: relative;
}

.project-card .project-tags {
    opacity: 0.7;
    transition: opacity 0.3s ease;
}

.project-card:hover .project-tags {
    opacity: 1;
}

.project-card:hover .project-tags span {
    background: rgba(147, 51, 234, 0.2);
    border-color: rgba(147, 51, 234, 0.4);
}

.project-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
}

.project-icon {
    font-size: 2rem;
}

.project-links {
    display: flex;
    gap: 12px;
}

.project-links a {
    padding: 4px;
    color: var(--text-muted);
    transition: var(--transition);
}

.project-links a:hover {
    transform: translateY(-2px);
    color: var(--accent-1);
}

.project-title {
    margin-bottom: 8px;
    font-size: 1.15rem;
    font-weight: 700;
}

.project-badge {
    display: inline-block;
    align-self: flex-start;
    margin-bottom: 12px;
    padding: 4px 12px;
    color: var(--accent-3);
    background: rgba(245, 158, 11, 0.1);
    border: 1px solid rgba(245, 158, 11, 0.2);
    border-radius: var(--radius-full);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
}

.project-desc {
    flex: 1;
    margin-bottom: 20px;
    color: var(--text-secondary);
    font-size: 0.9rem;
}

.project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: auto;
}

.project-tags span {
    padding: 4px 10px;
    color: var(--text-muted);
    background: rgba(255, 255, 255, 0.04);
    border-radius: var(--radius-sm);
    border: 1px solid rgba(255, 255, 255, 0.05);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    cursor: default;
}

.project-tags span:hover {
    background: rgba(147, 51, 234, 0.15);
    border-color: rgba(147, 51, 234, 0.3);
    color: var(--accent-1);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(147, 51, 234, 0.2);
}

.education-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 24px;
    margin-bottom: 40px;
}

.education-card {
    text-align: center;
}

.edu-icon {
    margin-bottom: 16px;
    font-size: 2.4rem;
}

.education-card h3 {
    margin-bottom: 8px;
    font-size: 1rem;
    font-weight: 700;
}

.edu-school {
    display: block;
    margin-bottom: 4px;
    color: var(--accent-2);
    font-size: 0.85rem;
}

.edu-date {
    display: block;
    margin-bottom: 12px;
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 0.8rem;
}

.education-card p {
    color: var(--text-secondary);
    font-size: 0.88rem;
}

.certs-row {
    display: flex;
    justify-content: center;
    gap: 24px;
}

.cert-badge {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 220px;
    padding: 28px 40px;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    transition: var(--transition);
}

.cert-badge:hover {
    transform: translateY(-4px);
    border-color: var(--border-glow);
}

.cert-score {
    margin-bottom: 8px;
    background: var(--gradient-text);
    background-clip: text;
    -webkit-text-fill-color: transparent;
    -webkit-background-clip: text;
    font-size: 2.2rem;
    font-weight: 900;
    line-height: 1;
}

.cert-name {
    font-size: 0.9rem;
    font-weight: 600;
}

.cert-detail {
    margin-top: 4px;
    color: var(--text-muted);
    font-size: 0.8rem;
}

#contact {
    padding-bottom: 80px;
}

.contact-lead {
    max-width: 560px;
    margin: 0 auto 48px;
    color: var(--text-secondary);
    text-align: center;
    font-size: 1.15rem;
}

.contact-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
    max-width: 640px;
    margin: 0 auto;
}

.contact-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 28px 20px;
    text-align: center;
}

.contact-icon {
    font-size: 1.8rem;
}

.contact-label {
    color: var(--text-muted);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
}

.contact-value {
    color: var(--accent-2);
    font-size: 0.85rem;
    font-weight: 500;
    word-break: break-word;
}

footer {
    padding: 32px 0;
    border-top: 1px solid var(--border-color);
    text-align: center;
}

footer p {
    color: var(--text-muted);
    font-size: 0.85rem;
}

.reveal {
    opacity: 1;
    transform: none;
}

.js .reveal {
    opacity: 0;
    transform: translateY(40px);
    transition: 
        opacity 0.8s cubic-bezier(0.4, 0, 0.2, 1),
        transform 0.8s cubic-bezier(0.4, 0, 0.2, 1);
}

.js .reveal.visible {
    opacity: 1;
    transform: translateY(0);
}

.js .reveal[data-reveal="fade-up"] {
    transform: translateY(60px);
}

.js .reveal[data-reveal="fade-left"] {
    transform: translateX(-40px);
}

.js .reveal[data-reveal="fade-right"] {
    transform: translateX(40px);
}

.js .reveal[data-reveal="scale"] {
    transform: scale(0.9);
}

.js .reveal[data-reveal="fade-up"].visible,
.js .reveal[data-reveal="fade-left"].visible,
.js .reveal[data-reveal="fade-right"].visible,
.js .reveal[data-reveal="scale"].visible {
    opacity: 1;
    transform: none;
}

@media (max-width: 980px) {
    .bento-about {
        grid-template-columns: 1fr 1fr;
        grid-template-areas:
            "image image"
            "bio bio"
            "thesis thesis"
            "lang1 lang2";
    }

    .bento-about .bento-image {
        max-width: 340px;
        margin: 0 auto;
        aspect-ratio: 3 / 4;
    }

    .bento-skills {
        grid-template-columns: 1fr;
        grid-template-areas:
            "brain"
            "hands"
            "voice";
    }

    .projects-grid {
        grid-template-columns: 1fr 1fr;
    }

    .projects-grid .project-card:first-child {
        grid-column: span 2;
    }

    .education-grid {
        grid-template-columns: 1fr;
    }

    .hero-stats {
        gap: 32px;
    }
}

@media (max-width: 768px) {
    .section {
        padding: 80px 0;
    }

    .section-title {
        margin-bottom: 40px;
    }

    .nav-toggle {
        display: flex;
        z-index: 1001;
    }

    .nav-panel {
        display: flex;
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        width: 100vw;
        height: 100vh;
        padding: 0;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 0;
        background: linear-gradient(
            180deg,
            rgba(5, 5, 10, 0.98) 0%,
            rgba(15, 10, 30, 0.98) 100%
        );
        backdrop-filter: blur(30px);
        overflow: hidden;
        opacity: 0;
        visibility: hidden;
        transform: scale(1.1);
        transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .nav-panel.open {
        opacity: 1;
        visibility: visible;
        transform: scale(1);
    }

    .nav-panel::before {
        content: '';
        position: absolute;
        top: 20%;
        left: 50%;
        width: 300px;
        height: 300px;
        background: radial-gradient(circle, rgba(147, 51, 234, 0.3) 0%, transparent 70%);
        filter: blur(60px);
        transform: translateX(-50%);
        pointer-events: none;
    }

    .nav-links {
        flex-direction: column;
        align-items: center;
        gap: 0;
        width: 100%;
        position: relative;
        z-index: 1;
    }

    .nav-links li {
        width: 100%;
        text-align: center;
        opacity: 0;
        transform: translateY(30px);
        transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .nav-panel.open .nav-links li {
        opacity: 1;
        transform: translateY(0);
    }

    .nav-panel.open .nav-links li:nth-child(1) { transition-delay: 0.1s; }
    .nav-panel.open .nav-links li:nth-child(2) { transition-delay: 0.15s; }
    .nav-panel.open .nav-links li:nth-child(3) { transition-delay: 0.2s; }
    .nav-panel.open .nav-links li:nth-child(4) { transition-delay: 0.25s; }
    .nav-panel.open .nav-links li:nth-child(5) { transition-delay: 0.3s; }
    .nav-panel.open .nav-links li:nth-child(6) { transition-delay: 0.35s; }
    .nav-panel.open .nav-links li:nth-child(7) { transition-delay: 0.4s; }

    .nav-links a {
        display: block;
        font-size: 2rem;
        font-weight: 600;
        padding: 20px 0;
        letter-spacing: -0.02em;
        background: linear-gradient(90deg, var(--text-primary) 0%, var(--text-secondary) 100%);
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
        transition: all 0.3s ease;
    }

    .nav-links a:hover {
        background: var(--gradient-primary);
        -webkit-background-clip: text;
        background-clip: text;
        transform: scale(1.05);
    }

    .nav-links a::before,
    .nav-links a::after {
        display: none !important;
    }

    .nav-cta {
        margin-top: 32px;
        padding: 18px 56px;
        font-size: 1.2rem;
        width: auto;
        min-width: 220px;
        text-align: center;
        display: block;
        opacity: 0;
        transform: translateY(20px);
        transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1) 0.45s;
    }

    .nav-panel.open .nav-cta {
        opacity: 1;
        transform: translateY(0);
    }

    .lang-switcher {
        margin-top: 24px;
        width: auto;
        min-width: 200px;
        justify-content: center;
        opacity: 0;
        transform: translateY(20px);
        transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1) 0.5s;
    }

    .nav-panel.open .lang-switcher {
        opacity: 1;
        transform: translateY(0);
    }

    .lang-switch {
        flex: 1;
        padding: 14px 24px;
        font-size: 1.1rem;
    }

    .hero-content {
        padding-top: 96px;
    }

    .hero-role-wrapper {
        flex-wrap: wrap;
    }

    .hero-stats {
        flex-direction: column;
        gap: 20px;
    }

    .certs-row {
        flex-direction: column;
        gap: 20px;
    }

    .bento-about {
        grid-template-columns: 1fr;
        grid-template-areas:
            "image"
            "bio"
            "thesis"
            "lang1"
            "lang2";
    }

    .bento-about .bento-image {
        max-width: 220px;
    }

    .bento-item.glass-card {
        padding: 24px;
    }

    .skill-tags {
        gap: 8px;
    }

    .skill-tag {
        padding: 6px 12px;
        font-size: 0.75rem;
    }

    .projects-grid {
        grid-template-columns: 1fr;
    }

    .projects-grid .project-card:first-child {
        grid-column: span 1;
    }

    .contact-grid {
        grid-template-columns: 1fr;
    }

    .timeline {
        padding-left: 36px;
    }

    .timeline-marker {
        left: -43px;
        width: 14px;
        height: 14px;
    }

    .timeline-marker::before {
        display: none;
    }

    #heroParticles {
        opacity: 0.4;
    }
}

@media (max-width: 480px) {
    .container {
        width: calc(100% - 32px);
    }

    .hero-name {
        font-size: clamp(2.2rem, 10vw, 3rem);
    }

    .hero-badge {
        font-size: 0.7rem;
        padding: 4px 12px;
    }

    .btn {
        padding: 12px 24px;
        font-size: 0.9rem;
    }

    .section-title {
        font-size: 1.5rem;
    }

    .bento-about .bento-image {
        max-width: 180px;
    }
}

@media (prefers-reduced-motion: reduce) {
    html {
        scroll-behavior: auto;
    }

    *,
    *::before,
    *::after {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
    }
}
